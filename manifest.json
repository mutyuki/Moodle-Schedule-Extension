{
  "manifest_version": 3,
  "name": "Moodle Schedule Extension",
  "version": "0.1.0",
  "description": "Chrome extension project for Moodle schedule support.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://lms.ritsumei.ac.jp/*",
    "https://withered-salad-b4aa.yudai-syllabus.workers.dev/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://lms.ritsumei.ac.jp/my/", "https://lms.ritsumei.ac.jp/my/index.php"],
      "js": [
        "src/unread-announcements/dom.js",
        "src/unread-announcements/api.js",
        "src/unread-announcements/content.js",
        "src/timetable/dom.js",
        "src/timetable/content.js",
        "src/timeline/utils.js",
        "src/timeline/dom.js",
        "src/timeline/content.js"
      ],
      "css": [
        "src/dashboard-layout.css",
        "src/unread-announcements/style.css",
        "src/timetable/style.css",
        "src/timeline/style.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://lms.ritsumei.ac.jp/*"],
      "js": [
        "src/timetable/syllabus-button/cache.js",
        "src/timetable/syllabus-button/api.js",
        "src/timetable/syllabus-button/dom.js",
        "src/timetable/syllabus-button/content.js"
      ],
      "css": ["src/timetable/syllabus-button/style.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
