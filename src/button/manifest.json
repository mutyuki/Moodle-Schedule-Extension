{
  "manifest_version": 3,
  "name": "Moodle Schedule Extension",
  "version": "1.0",
  "description": "Moodleから授業情報を取得する拡張機能",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": ["https://lms.ritsumei.ac.jp/*"],
  "content_scripts": [
    {
      "matches": ["https://lms.ritsumei.ac.jp/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
