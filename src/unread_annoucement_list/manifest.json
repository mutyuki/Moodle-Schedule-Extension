{
  "manifest_version": 3,
  "name": "Moodle+R ダッシュボード拡張",
  "version": "1.1",
  "description": "立命館大学Moodle+Rのダッシュボードを2段組（タイムライン+未読アナウンス）にします。My時間割表・コース概要はそのまま1列表示。",
  "permissions": ["storage"],
  "host_permissions": ["https://lms.ritsumei.ac.jp/*"],
  "content_scripts": [
    {
      "matches": ["https://lms.ritsumei.ac.jp/my/", "https://lms.ritsumei.ac.jp/my/index.php"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
